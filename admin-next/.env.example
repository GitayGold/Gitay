# ════════════════════════════════════════════════════════════════
# Gitay Gold Admin — Environment Variables Template
#
# 1. Copy this file to `.env.local` (which is gitignored).
# 2. Fill in the values from Supabase → Project Settings → API.
# 3. Restart `npm run dev` after editing.
# ════════════════════════════════════════════════════════════════

# Public — exposed to the browser. Safe by design.
# Found in: Supabase → Project Settings → API → "Project URL"
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Public — exposed to the browser. Anonymous role; bound by RLS.
# Found in: Supabase → Project Settings → API → "anon public" key
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE

# ────────────────────────────────────────────────────────────────
# Phase 2: required for server-side admin operations (Server
# Actions, image-upload bypass, programmatic seeding).
# Server-only — never prefix with NEXT_PUBLIC_.
# Found in: Supabase → Project Settings → API → "service_role" key
# Keep commented until Phase 2 wires it up.
# ────────────────────────────────────────────────────────────────
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
